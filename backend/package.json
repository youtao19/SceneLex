{
  "name": "wordscene-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "mkdir -p .tmp && TMPDIR=$PWD/.tmp ts-node-dev --cache-directory ./.tmp/ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dict:download": "node scripts/download-ecdict.js",
    "dict:build-cache": "node scripts/build-dictionary-cache.js",
    "dict:import-db": "node scripts/import-dictionary-cache.js",
    "wordbook:import:cet6": "node scripts/import-cet6-word-book.js",
    "wordbook:import:cet6:json": "node scripts/import-cet6-from-json.js",
    "wordbook:prewarm": "node -r ../node_modules/ts-node/register/transpile-only scripts/prewarm-system-word-cards.ts",
    "wordbook:prewarm:cet6": "npm run wordbook:prewarm -- --book cet6 --limit 99999",
    "key:create": "node scripts/create-access-key.js"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
