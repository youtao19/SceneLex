# Backend server
PORT=3003
NODE_ENV=development

# AI provider: ollama、omlx 或 deepseek
AI_PROVIDER=ollama

# PostgreSQL
# 格式示例：
# DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME
DATABASE_URL=postgresql://YOUR_USERNAME:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DATABASE

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT=60000
OCR_MODEL=gemma4:e4b
OCR_TIMEOUT=180000
OCR_VISION_PROVIDER=ollama
OCR_SERVICE_URL=http://127.0.0.1:8001/ocr
PADDLE_OCR_TIMEOUT=300000

# Kimi vision OCR
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6
KIMI_OCR_TIMEOUT=180000
KIMI_API_KEY=

# oMLX
# oMLX 默认提供 OpenAI-compatible API，base URL 要带 /v1。
OMLX_BASE_URL=http://localhost:8000/v1
OMLX_MODEL=Qwen3.5-4B-MLX-4bit
OMLX_TIMEOUT=60000
OMLX_API_KEY=

# DeepSeek
# DeepSeek 使用 OpenAI-compatible API，base URL 不需要带 /v1。
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=120000
DEEPSEEK_API_KEY=

# Model traffic controls
MODEL_GLOBAL_CONCURRENCY=3
MODEL_USER_CONCURRENCY=1
MODEL_RATE_LIMIT_MAX=10
MODEL_QUEUE_TIMEOUT_MS=30000
